# Supabase project URL
SUPABASE_URL=https://pukwbixdjqzrowupibpi.supabase.co

# Service role key — server only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=sb_publishable_50qbElYzO-6iy3XbPFXKPA_w5CPRJdw



# JWT secret: Supabase Dashboard → Settings → API → JWT Secret (used to verify access tokens)
SUPABASE_JWT_SECRET=your_jwt_secret

# Comma-separated allowed frontend origins (Vite may use 5174 if 5173 is busy)
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:5174,https://your-app.vercel.app

# Render/Railway sets PORT automatically
PORT=8000
